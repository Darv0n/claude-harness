    "file_io": [
      {
        "name": "Read",
        "category": "file_io",
        "description": "Read file contents from local filesystem. Supports text, images, PDFs, Jupyter notebooks.",
        "parameters": {
          "file_path": { "type": "string", "required": true, "description": "Absolute path to file" },
          "offset": { "type": "integer", "required": false, "description": "Line number to start from" },
          "limit": { "type": "integer", "required": false, "description": "Number of lines to read" },
          "pages": { "type": "string", "required": false, "description": "Page range for PDFs (e.g., '1-5')" }
        },
        "output": "File contents with line numbers (cat -n format)",
        "constraints": ["Must use absolute paths", "Default 2000 line limit", "PDF max 20 pages per request"],
        "agent_access": "Available to all agents by default"
      },
      {
        "name": "Write",
        "category": "file_io",
        "description": "Write or overwrite file on local filesystem.",
        "parameters": {
          "file_path": { "type": "string", "required": true, "description": "Absolute path to file" },
          "content": { "type": "string", "required": true, "description": "Content to write" }
        },
        "constraints": ["Must Read file first if it exists", "Overwrites existing content", "Prefer Edit for modifications"],
        "agent_access": "Requires explicit grant in agent tools list"
      },
      {
        "name": "Edit",
        "category": "file_io",
        "description": "Exact string replacement in files. Sends only the diff.",
        "parameters": {
          "file_path": { "type": "string", "required": true },
          "old_string": { "type": "string", "required": true, "description": "Text to find (must be unique)" },
          "new_string": { "type": "string", "required": true, "description": "Replacement text" },
          "replace_all": { "type": "boolean", "required": false, "default": false }
        },
        "constraints": ["Must Read file first", "old_string must be unique unless replace_all=true"],
        "agent_access": "Requires explicit grant"
      },
      {
        "name": "Glob",
        "category": "file_io",
        "description": "Fast file pattern matching. Find files by name patterns.",
        "parameters": {
          "pattern": { "type": "string", "required": true, "description": "Glob pattern (e.g., '**/*.ts')" },
          "path": { "type": "string", "required": false, "description": "Directory to search in" }
        },
        "output": "Matching file paths sorted by modification time",
        "agent_access": "Available to most agents"
      },
      {
        "name": "Grep",
        "category": "file_io",
        "description": "Content search using ripgrep. Full regex support.",
        "parameters": {
          "pattern": { "type": "string", "required": true, "description": "Regex pattern" },
          "path": { "type": "string", "required": false },
          "glob": { "type": "string", "required": false, "description": "File filter (e.g., '*.ts')" },
          "output_mode": { "type": "string", "enum": ["content", "files_with_matches", "count"] },
          "context": { "type": "integer", "required": false },
          "multiline": { "type": "boolean", "required": false }
        },
        "agent_access": "Available to most agents"
      }
    ],
