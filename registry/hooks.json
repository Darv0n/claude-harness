          "HOOK_TOOL_NAME": "Tool name",
          "HOOK_TOOL_INPUT": "JSON input to the tool"
        }
      },
      "exit_codes": {
        "0": "Allow execution to proceed",
        "1": "Deny/block execution",
        "other": "Failure — stops hook chain"
      },
      "output_behavior": "stdout becomes system message (warning/guidance). Non-zero exit blocks the tool.",
      "can_return": ["permission_override (Allow/Deny/Ask)", "updated_input", "messages"],
